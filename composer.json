{
    "name": "fooino/core",
    "description": "The fooino core package with tools and functionalities.",
    "type": "library",
    "license": "proprietary",
    "authors": [
        {
            "name": "Sajad Sholi",
            "email": "sajadsholidev@gmail.com",
            "role": "owner"
        }
    ],
    "require": {
        "php": "^8.5",
        "ext-bcmath": "*",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "morilog/jalali": "^3.5"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpdocumentor/shim": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "Fooino\\Core\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Fooino\\Core\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Fooino\\Core\\Providers\\CoreServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpdocumentor/shim": true
        }
    },
    "scripts": {
        "pest": "./vendor/bin/pest",
        "phpdoc": "./vendor/bin/phpdoc"
    }
}