<?xml version="1.0" encoding="UTF-8" ?>
<phpdoc>
    <title>Core Package docs</title>
    <parser>
        <target>docs/core</target>
    </parser>
    <transformer>
        <target>docs/core</target>
    </transformer>
    <files>
        <directory>./src</directory>
        <ignore>./vendor/*</ignore>
        <ignore>./tests/*</ignore>
        <ignore>./docs/*</ignore>
        <ignore>./coverage/*</ignore>
    </files>
</phpdoc>